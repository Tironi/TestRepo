{
  "name": "my-mcp-server",
  "type": "module",
  "version": "1.0.0",
  "description": "MCP server: my-mcp-server",
  "author": "",
  "license": "MIT",
  "keywords": [
    "mcp",
    "server",
    "starter",
    "tools",
    "resources",
    "prompts",
    "uiresource",
    "ui",
    "react",
    "widgets",
    "mcp-ui",
    "apps-sdk"
  ],
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "mcp-use generate-types || true",
    "build": "mcp-use build",
    "dev": "tsc --outDir dist --skipLibCheck & mcp-use build --with-inspector --no-typecheck & mcp-use start",
    "start": "mcp-use start",
    "deploy": "mcp-use deploy"
  },
  "dependencies": {
    "@openai/apps-sdk-ui": "^0.2.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^16.4.7",
    "mcp-use": "https://pkg.pr.new/mcp-use@1f1460f",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.0",
    "tailwindcss": "^4.2.0",
    "vite": "^8.0.3",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
